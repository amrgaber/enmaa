<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default JWT Secret -->
        <record id="param_jwt_secret" model="ir.config_parameter">
            <field name="key">fastapi_v19_auth.jwt_secret_key</field>
            <field name="value">fastapi-v19-auth-secret-key-change-in-production</field>
        </record>

        <!-- Default Client ID for testing -->
        <record id="param_client_id" model="ir.config_parameter">
            <field name="key">fastapi_v19_auth.client_id</field>
            <field name="value">api_client</field>
        </record>

        <!-- Default Client Secret for testing -->
        <record id="param_client_secret" model="ir.config_parameter">
            <field name="key">fastapi_v19_auth.client_secret</field>
            <field name="value">api_secret_change_in_production</field>
        </record>

        <!-- Default Access Token Expiry -->
        <record id="param_access_expire_min" model="ir.config_parameter">
            <field name="key">fastapi_v19_auth.access_token_expire_minutes</field>
            <field name="value">60</field>
        </record>
    </data>
</odoo>
