<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Analytic Plan field to Product Template form -->
    <record id="view_product_template_form_inherit_third_party" model="ir.ui.view">
        <field name="name">product.template.form.inherit.third.party</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Position it after Category -->
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="analytic_plan_id" 
                       string="Analytic Plan"
                       options="{'no_create': True}"/>
                <field name="internal_ref"/>
            </xpath>
        </field>
    </record>
</odoo>
