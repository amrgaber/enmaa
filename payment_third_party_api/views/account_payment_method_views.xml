<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_method_form_inherit" model="ir.ui.view">
        <field name="name">payment.method.form.inherit.payment.third.party</field>
        <field name="model">payment.method</field>
        <field name="inherit_id" ref="payment.payment_method_form"/>
        <field name="arch" type="xml">
             <xpath expr="//sheet/notebook" position="inside">
                <page string="Third Party" name="third_party" invisible="not is_primary">
                    <group>
                        <field name="third_party_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
